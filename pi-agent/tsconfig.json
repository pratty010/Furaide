{
  "compilerOptions": {
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],
    "types": ["bun", "node"]
  },
  "include": [
    "src/**/*",
    "skills/**/*",
    "agents/**/*"
  ]
}
