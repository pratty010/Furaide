  "pi": {
    "extensions": ["./src/index.ts"],
    "themes": ["./themes"],
    "skills": ["./skills"]
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.49",
    "@types/turndown": "^5.0.6",
    "@xenova/transformers": "^2.17.2",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.4",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5.7.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
