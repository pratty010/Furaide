{
  "name": "friday-furaidee",
  "version": "0.1.0",
  "description": "Furaidē's Pi extension: web-RAG tools, /usage analytics, TUI widgets, themes, and GSD skills",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src/", "themes/", "skills/", "agents/", "config/"],
