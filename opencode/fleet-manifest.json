{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "Single source of truth for install-fleet.sh. Edit here, not in the installer.",
  "components": [
    {
      "id": "workflow-gates",
      "label": "Workflow Gates",
      "description": "Fail-closed gate plugins (Nio, Nurikabe) and the workflow state engine they exec. Cannot be split.",
      "atomic": true,
      "coupling": "nio.js and nurikabe.js exec scripts/workflow-state.mjs at runtime",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "plugins",
        "scripts",
        "docs"
      ],
      "files": [
        "plugins/nio.js",
        "plugins/nurikabe.js",
        "scripts/workflow-state.mjs",
        "scripts/state-path.mjs",
        "docs/workflows.md"
      ],
      "globs": [
        "scripts/lib/**"
      ]
    },
    {
      "id": "failover",
      "label": "Model Failover",
      "description": "Migawari plugin and the routing manifest it reads. Cannot be split.",
      "atomic": true,
      "coupling": "migawari.js reads docs/routing-manifest.json at runtime",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "plugins",
        "docs"
      ],
      "files": [
        "plugins/migawari.js",
        "docs/routing-manifest.json"
      ],
      "globs": []
    },
    {
      "id": "security-gate",
      "label": "Security Gate",
      "description": "Komainu plugin: screens Edit/Write calls for 35+ dangerous code patterns. Standalone.",
      "atomic": false,
      "coupling": "none",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "plugins"
      ],
      "files": [
        "plugins/komainu.js"
      ],
      "globs": []
    },
    {
      "id": "session-vault",
      "label": "Session Vault",
      "description": "Global session vault command, close-hook plugin, helper, and tests.",
      "atomic": true,
      "coupling": "command/session-vault.md depends on plugins/omokage.js and scripts/session-vault.mjs",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "command",
        "plugins",
        "scripts"
      ],
      "files": [
        "command/session-vault.md",
        "plugins/omokage.js",
        "scripts/session-vault.mjs"
      ],
      "globs": [
        "scripts/lib/session-vault-*.mjs",
        "scripts/tests/session-vault-*.test.mjs"
      ]
    },
    {
      "id": "agents-core",
      "label": "Specialist Agents (30 core)",
      "description": "30 specialist and subagent shikigami (12 specialists + 16 subagents + 2 escape-hatch). Soft dependency on failover routing-manifest.json and docs/models/** for model selection.",
      "atomic": false,
      "coupling": "soft dep on failover routing-manifest.json; auto-included at same scope if failover not selected there",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "agents"
      ],
      "files": [
        "agents/azukiarai--data-sifter.md",
        "agents/bakeneko--bug-hunter.md",
        "agents/daidarabotchi--infra-shaper.md",
        "agents/daikoku--finance-steward.md",
        "agents/enma--compliance-judge.md",
        "agents/fudo--security-guardian.md",
        "agents/henge--format-shifter.md",
        "agents/jorogumo--synthesis-weaver.md",
        "agents/kagami--truth-mirror.md",
        "agents/karakuri--command-runner.md",
        "agents/karasutengu--docs-scout.md",
        "agents/kotodama--prose-polisher.md",
        "agents/makimono--docs-scribe.md",
        "agents/mikoshi--code-pathfinder.md",
        "agents/mujina--brand-shapeshifter.md",
        "agents/oni--red-team-reviewer.md",
        "agents/soroban--number-sage.md",
        "agents/tanuki--general-trickster.md",
        "agents/tanuki--codemod-runner.md",
        "agents/tengu--visual-artisan.md",
        "agents/tsuchigumo--research-weaver.md",
        "agents/tsukumogami--code-forgemaster.md",
        "agents/tsukuyomi--spec-oracle.md",
        "agents/yamabiko--source-echo.md",
        "agents/yumemi--story-smith.md",
        "agents/hanko--git-seal.md",
        "agents/sojobo--system-strategist.md",
        "agents/shiranui--migration-guide.md",
        "agents/chizu--implementation-planner.md",
        "agents/mizuchi--data-current.md"
      ],
      "globs": []
    },
    {
      "id": "agent-scripts",
      "label": "Agent Support Scripts",
      "description": "Verification and safety scripts called by agents via karakuri--command-runner (code runner). No hard coupling.",
      "atomic": false,
      "coupling": "none (agents call via karakuri--command-runner subagent)",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "scripts"
      ],
      "files": [
        "scripts/action-allowlist.mjs",
        "scripts/citation-verify.mjs",
        "scripts/ctx7-docs.mjs",
        "scripts/humanize-check.mjs",
        "scripts/memory-path.mjs",
        "scripts/playbook-check.mjs",
        "scripts/security-severity.mjs",
        "scripts/sql-safety-check.mjs",
        "scripts/verify-run.mjs",
        "scripts/voice-check.mjs"
      ],
      "globs": []
    },
    {
      "id": "rules",
      "label": "Rules",
      "description": "Memory contract and other rules loaded via instructions glob in opencode.json.",
      "atomic": false,
      "coupling": "wired via instructions glob in opencode.json",
      "requires_bun": false,
      "default_on": true,
      "target_subdirs": [
        "rules"
      ],
      "files": [],
      "globs": [
        "rules/*.md"
      ]
    },
    {
      "id": "docs-reference",
      "label": "Reference Docs",
      "description": "OPERATOR guide, architecture overview, manifest schema, agent template, model family guides, and shared GitHub workflow guide. Reference only, not required at runtime.",
      "atomic": false,
      "coupling": "reference only; GITHUB.md and github-setup-check.sh sourced from common/ at install time",
      "requires_bun": false,
      "default_on": false,
      "target_subdirs": [
        "docs",
        "scripts"
      ],
      "files": [
        "docs/OPERATOR.md",
        "docs/architecture.md",
        "docs/manifest-schema.md",
        "docs/agent-template.md"
      ],
      "common_files": [
        {
          "src": "../common/docs/GITHUB.md",
          "dst": "docs/GITHUB.md"
        },
        {
          "src": "../common/scripts/github-setup-check.sh",
          "dst": "scripts/github-setup-check.sh"
        }
      ],
      "globs": [
        "docs/models/**"
      ]
    },
    {
      "id": "brand-builder",
      "label": "Brand Builder / Kitsune (opt-in)",
      "description": "Kitsune's full domain: 9 brand agents, brand plugin, commands, and skills. Requires bun install. Opens a per-project SQLite DB on init.",
      "atomic": true,
      "coupling": "brand-builder-plugin depends on its own node_modules; brand agents depend on brand commands and skills",
      "requires_bun": true,
      "default_on": false,
      "target_subdirs": [
        "agents",
        "command",
        "skills",
        "brand-builder-plugin"
      ],
      "files": [
        "agents/akashi--proof-keeper.md",
        "agents/amanojaku--voice-contrarian.md",
        "agents/hyakume--ats-watchman.md",
        "agents/kataribe--narrative-teller.md",
        "agents/kitsune--brand-orchestrator.md",
        "agents/kodama--growth-echo.md",
        "agents/kudagitsune--fit-diviner.md",
        "agents/kurabokko--knowledge-keeper.md",
        "agents/migaki--profile-polisher.md"
      ],
      "globs": [
        "command/*.md",
        "skills/**",
        "brand-builder-plugin/**"
      ]
    }
  ]
}
