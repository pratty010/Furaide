{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "lsp": true,
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "./plugins/gate-enforcer.js",
    "./plugins/delivery-gate.js",
    "./plugins/security-patterns.js",
    "./plugins/model-failover.js"
  ],
  "instructions": [
    "/home/ace/.config/opencode/rules/*.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  },
  "provider": {
    "openai": {
      "whitelist": [
        "gpt-5.2",
        "gpt-5.3-codex",
        "gpt-5.4-mini",
        "gpt-5.4",
        "gpt-5.5"
      ]
    },
    "google-vertex": {
      "whitelist": [
        "gemini-3-flash-preview",
        "gemini-3.1-flash-lite",
        "gemini-3.1-pro-preview",
        "gemini-3.1-pro-preview-customtools",
        "gemini-3.5-flash"
      ]
    },
    "google": {
      "whitelist": [
        "gemma-4-26b-a4b-it",
        "gemma-4-31b-it"
      ]
    },
    "opencode": {
      "whitelist": [
        "big-pickle",
        "nemotron-3-super-free",
        "deepseek-v4-flash-free",
        "mimo-v2.5-free"
      ]
    },
    "opencode-go": {
      "whitelist": [
        "kimi-k2.6",
        "kimi-k2.5",
        "glm-5.1",
        "glm-5",
        "qwen3.7-max",
        "qwen3.6-plus",
        "deepseek-v4-pro",
        "deepseek-v4-flash",
        "minimax-m2.7",
        "mimo-v2.5",
        "mimo-v2.5-pro"
      ]
    }
  },
  "disabled_providers": ["google-vertex-anthropic"],
  "permission": {
    "*": "allow",
    "edit": "ask",
    "bash": "ask"
  },
  "agent": {
    "general": {
      "model": "opencode/big-pickle"
    }
  }
}
